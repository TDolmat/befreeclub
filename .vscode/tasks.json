{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend (FastAPI :3000)",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --port 3000 --reload",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "icon": { "id": "server-process", "color": "terminal.ansiGreen" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Admin front (Vite :5173)",
      "type": "shell",
      "command": "pnpm dev",
      "options": { "cwd": "${workspaceFolder}/frontends" },
      "icon": { "id": "globe", "color": "terminal.ansiMagenta" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Stripe webhooki (CLI listen)",
      "type": "shell",
      "command": "stripe listen --forward-to localhost:3000/api/billing/webhooks/stripe/current",
      "icon": { "id": "credit-card", "color": "terminal.ansiCyan" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "DB: migracje (alembic upgrade head)",
      "type": "shell",
      "command": "uv run alembic upgrade head",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "icon": { "id": "database", "color": "terminal.ansiYellow" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Testy: backend (pytest)",
      "type": "shell",
      "command": "uv run pytest tests/ -q",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "icon": { "id": "beaker", "color": "terminal.ansiBlue" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Lint: backend (ruff)",
      "type": "shell",
      "command": "uv run ruff check .",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "icon": { "id": "checklist", "color": "terminal.ansiRed" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Typecheck+lint: front (pnpm)",
      "type": "shell",
      "command": "pnpm typecheck && pnpm lint",
      "options": { "cwd": "${workspaceFolder}/frontends" },
      "icon": { "id": "checklist", "color": "terminal.ansiMagenta" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },

    {
      "label": "Run All (dev)",
      "dependsOn": ["Backend (FastAPI :3000)", "Admin front (Vite :5173)"],
      "dependsOrder": "parallel",
      "icon": { "id": "run-all", "color": "terminal.ansiGreen" },
      "problemMatcher": []
    },
    {
      "label": "Run All (dev + Stripe)",
      "dependsOn": ["Backend (FastAPI :3000)", "Admin front (Vite :5173)", "Stripe webhooki (CLI listen)"],
      "dependsOrder": "parallel",
      "icon": { "id": "run-all", "color": "terminal.ansiCyan" },
      "problemMatcher": []
    }
  ]
}
