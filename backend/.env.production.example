# Prod (VPS). Kopiowany do backend/.env:
#   cp backend/.env.production.example backend/.env
# Czyta go docker compose (env_file) oraz - przez symlink infra/.env -
# interpolacja ${DB_PASS} w infra/docker-compose.yml. Jeden plik sekretow.
#
# NODE_ENV, PORT, DB_HOST, DB_PORT, CLAUDE_BIN_PATH i WEB_DIST_PATH sa twardo
# nadpisane w compose (sekcja environment) - tu ich nie ustawiaj.

# Haslo Postgresa (openssl rand -hex 24). To samo trafia do kontenera db
# (POSTGRES_PASSWORD) i do backendu (DB_PASS).
DB_PASS=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Baza w sieci dockerowej. DATABASE_URL puste = backend sklada DSN z DB_*.
DATABASE_URL=
DB_USER=befreeclub
DB_NAME=befreeclub

LOG_LEVEL=info

# Modele Claude: draft/iteracje (tani, szybki) vs polish pass (najwyzsza jakosc).
DRAFT_MODEL=claude-sonnet-4-6
POLISH_MODEL=claude-opus-4-7
# Max rownoleglych procesow claude (presja na subskrypcje Max).
CLAUDE_MAX_CONCURRENT=2
POLLING_INTERVAL_MS=30000

KB_BUDGET_TOKENS=60000
KB_HARD_CEILING_TOKENS=90000

# Puste = workery voice/image wylaczone (WARN przy boocie, ticki pomijane).
# Wymagane w prod, zeby kontekst [glosowka]/[obrazek] docieral do AI.
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
VOICE_TRANSCRIPT_INTERVAL_MS=20000
IMAGE_DESCRIPTION_INTERVAL_MS=20000

# Master key do szyfrowania edytowalnych kluczy API w panelu (Polaczenia API):
# OpenAI/Resend/Sender/Meta da sie wpisac w panelu, leza zaszyfrowane Fernetem.
# WYGENERUJ NOWY na prod (NIE z dev, rotacja = utrata zapisanych kluczy):
#   openssl rand -base64 32 | tr '+/' '-_'   (44-znakowy klucz Fernet)
# Puste = edycja kluczy w panelu wylaczona (cichy fallback na env, nie crash).
SECRETS_MASTER_KEY=

# Opcjonalny bootstrap pierwszego konta Circle (circle_dm.accounts) przy
# pierwszym starcie. To NIE jest konto logowania do panelu - te tworzy
# set-auth-password. Token mintuje JWT dla dowolnego czlonka - sekret.
BOOTSTRAP_ADMIN_LABEL=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_TOKEN=

# Front serwuje osobny kontener nginx (bfc-admin-front). Puste = backend nie
# serwuje SPA. W prod NIE ustawiac (compose i tak wymusza puste).
WEB_DIST_PATH=

# ── Faza 2: landing befreeclub.pl ──────────────────────────────────────────
# Nazwy identyczne z sekretami Supabase (docs/spec-landing/config-deploy.md).
# Puste = funkcja wylaczona BEZ bledu przy boocie - przy przepieciu landinga
# (faza 2.5) WYMAGANE sa: STRIPE_*, CIRCLE_*, RESEND_API_KEY, sekrety DOI.
# Bez STRIPE_WEBHOOK_SECRET webhooki Stripe dostaja 500 "Webhook not
# configured"; bez RESEND/CIRCLE maile i provisioning sa cicho wylaczone.

# Stripe: konto current (cala sprzedaz) + legacy (stare suby). 4 sekrety.
STRIPE_SECRET_KEY=
STRIPE_LEGACY_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LEGACY_WEBHOOK_SECRET=

# Circle Admin API (provisioning czlonkostw).
CIRCLE_API_TOKEN=
CIRCLE_COMMUNITY_ID=

# Maile (Resend) + sekrety HMAC magic linkow (anulowanie/zmiana karty, DOI).
RESEND_API_KEY=
CANCELLATION_DOI_SECRET=
CANCELLATION_FROM_EMAIL=
NEWSLETTER_DOI_SECRET=
NEWSLETTER_FROM_EMAIL=

# URL-e frontu (puste = defaulty https://befreeclub.pl[/newsletter/potwierdz]).
CONFIRM_URL_BASE=
FRONTEND_URL=

# Sender.net (newsletter) - UWAGA: stary token wyciekl, zrotowac przy migracji.
SENDER_API_TOKEN=
SENDER_GROUP_IDS=

# Meta Conversions API (Purchase/Lead z webhookow).
META_PIXEL_ID=
META_CAPI_TOKEN=

# PDF ebooka na wolumenie (compose montuje ../data/ebook -> /data/ebook).
EBOOK_FILE_PATH=/data/ebook/Na-swoich-zasadach-jako-freelancer.pdf

# Interwaly workerow fazy 2 (ms) - INTY, nie zostawiac pustych.
# Cleanup: default 6 h, DO POTWIERDZENIA ze zrzutem cron.job z Supabase.
MEMBERSHIP_CLEANUP_INTERVAL_MS=21600000
KLARNA_RECONCILE_INTERVAL_MS=3600000
INVITE_RETRY_INTERVAL_MS=3600000
