# Production (VPS). Copied to backend/.env:
#   cp backend/.env.production.example backend/.env
# Read by docker compose (env_file) and, via the infra/.env symlink, used to
# interpolate ${DB_PASS} in infra/docker-compose.yml. Single secrets file.
#
# NODE_ENV, PORT, DB_HOST, DB_PORT, CLAUDE_BIN_PATH and WEB_DIST_PATH are forced
# in compose (environment section) - do not set them here.
#
# "default; editable in panel" = the value below is only the boot default. The
# admin panel (DB) overrides it at runtime, no redeploy needed.

# Postgres password (openssl rand -hex 24). Goes to both the db container
# (POSTGRES_PASSWORD) and the backend (DB_PASS).
DB_PASS=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# DB on the docker network. Empty DATABASE_URL = backend builds the DSN from DB_*.
DATABASE_URL=
DB_USER=befreeclub
DB_NAME=befreeclub

LOG_LEVEL=info

# Claude models: draft/iteration (cheap, fast) vs polish pass (highest quality).
# default; editable in the Circle DM tool settings (/circle-dm/settings, "AI models").
# Note: POLISH_MODEL is labelled "Format model" there.
DRAFT_MODEL=claude-sonnet-4-6
POLISH_MODEL=claude-opus-4-7

# default; editable in Settings > Circle DM & AI.
CLAUDE_MAX_CONCURRENT=2          # max parallel claude processes (pressure on the Max plan)
POLLING_INTERVAL_MS=30000
KB_BUDGET_TOKENS=60000
KB_HARD_CEILING_TOKENS=90000

# OpenAI key. Empty = voice/image workers off (WARN at boot, ticks skipped).
# Settable in the panel (API connections), Fernet-encrypted; env is the fallback.
OPENAI_API_KEY=
# default; editable in Settings > Circle DM & AI.
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
VOICE_TRANSCRIPT_INTERVAL_MS=20000
IMAGE_DESCRIPTION_INTERVAL_MS=20000

# Master key that encrypts the panel-editable API keys (API connections):
# OpenAI/Resend/Sender/Meta can be set in the panel, stored Fernet-encrypted.
# Generate a NEW one for prod (NOT the dev one; rotating loses saved keys):
#   openssl rand -base64 32 | tr '+/' '-_'   (44-char Fernet key)
# Empty = editing keys in the panel is disabled (silent env fallback, no crash).
SECRETS_MASTER_KEY=

# Optional bootstrap of the first Circle account (circle_dm.accounts) on first
# start. This is NOT a panel login account - those are made with set-auth-password.
# The token mints a JWT for any member, so it is a secret. env only.
BOOTSTRAP_ADMIN_LABEL=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_TOKEN=

# Front is served by a separate nginx container (bfc-admin-front). Empty = backend
# does not serve the SPA. In prod leave empty (compose forces it anyway).
WEB_DIST_PATH=

# ── Phase 2: landing befreeclub.pl ───────────────────────────────────────────
# Names match the Supabase secrets (docs/spec-landing/config-deploy.md). Empty =
# feature off, no boot error. At landing cutover (phase 2.5) these are REQUIRED:
# STRIPE_*, CIRCLE_*, RESEND_API_KEY, DOI secrets. Without STRIPE_WEBHOOK_SECRET
# Stripe webhooks return 500 "Webhook not configured"; without RESEND/CIRCLE
# mail and provisioning are silently off.

# Stripe: current account (all sales) + legacy (old subs). 4 secrets, env only
# (the panel shows status + test only, never editable).
STRIPE_SECRET_KEY=
STRIPE_LEGACY_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LEGACY_WEBHOOK_SECRET=

# Circle Admin API token (member provisioning). Secret, env only (panel: status).
CIRCLE_API_TOKEN=
# default; editable in Settings > Analytics.
CIRCLE_COMMUNITY_ID=

# Resend API key: settable in the panel (API connections), encrypted; env fallback.
RESEND_API_KEY=
# DOI HMAC secrets (cancellation / card-change magic links). Secret, env only.
CANCELLATION_DOI_SECRET=
# default; editable in Settings > Billing & Newsletter.
CANCELLATION_FROM_EMAIL=
NEWSLETTER_DOI_SECRET=
# default; editable in Settings > Billing & Newsletter.
NEWSLETTER_FROM_EMAIL=

# default; editable in Settings > Billing & Newsletter.
# Empty = defaults https://befreeclub.pl[/newsletter/potwierdz].
CONFIRM_URL_BASE=
FRONTEND_URL=

# Sender.net token: settable in the panel (API connections), encrypted; env
# fallback. NOTE: the old token leaked, rotate it at migration.
SENDER_API_TOKEN=
# default; editable in Settings > Billing & Newsletter.
SENDER_GROUP_IDS=

# Meta Conversions API. META_CAPI_TOKEN: settable in the panel (API connections),
# encrypted; env fallback. META_PIXEL_ID: default; editable in Settings > Analytics.
META_PIXEL_ID=
META_CAPI_TOKEN=

# Ebook PDF on a volume (compose mounts ../data/ebook -> /data/ebook).
# default; editable in Settings > Billing & Newsletter.
EBOOK_FILE_PATH=/data/ebook/Na-swoich-zasadach-jako-freelancer.pdf

# Phase-2 worker intervals (ms) - INTs, do not leave empty.
# default; editable in Settings > Membership. Cleanup default 6 h - CONFIRM
# against the cron.job dump from Supabase.
MEMBERSHIP_CLEANUP_INTERVAL_MS=21600000
KLARNA_RECONCILE_INTERVAL_MS=3600000
INVITE_RETRY_INTERVAL_MS=3600000
