# Backend Be Free Club - zmienne srodowiskowe.
# Te same nazwy co w starym backendzie Node (admin/apps/server/.env.example).
# Pusta wartosc = brak / funkcja wylaczona / default w kodzie.
# Jedyne autorytatywne zrodlo env: app/core/config.py (klasa Settings).
#
# Trzy sekcje:
#   (A) SEKRETY - musza byc w env na serwerze, NIGDY nie ida do panelu/DB jako wartosc.
#       Panel pokazuje tylko status + test polaczenia (Polaczenia API).
#   (B) NIESEKRETNE USTAWIENIA - ustawiasz je w panelu (Ustawienia), env to tylko fallback.
#       DB nadpisuje env. Tu mozesz zostawic puste/zakomentowane, jesli wolisz panel.
#   (C) INFRA / DEV - boot, baza, flagi mockow. Zostaja w env.


# ============================================================
# (A) SEKRETY - wymagane w env, nigdy do panelu
# Panel: status-only + test polaczenia. Wartosci trzymaj tylko tutaj.
# ============================================================

# -- Master key do edytowalnych sekretow w panelu (Fernet). Szyfruje klucze
#    OpenAI/Resend/Sender/Meta zapisywane w panelu (Polaczenia API). Pusty = panel
#    nie szyfruje (edycja kluczy w panelu wylaczona), env nizej dziala normalnie.
#    Wygeneruj: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_MASTER_KEY=

# -- OpenAI (STT/whisper + vision). Poza prod brak = mock.
#    Te 4 (OpenAI, Resend, Sender, Meta CAPI) sa tez edytowalne w panelu - env to fallback.
OPENAI_API_KEY=

# -- Stripe konto CURRENT (status-only w panelu, NIE edytowalny). Lokalnie TYLKO sk_test_ (sk_live_ poza prod blokuje start).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -- Stripe konto LEGACY (drugie konto). Wypelnij tylko jesli uzywane.
STRIPE_LEGACY_SECRET_KEY=
STRIPE_LEGACY_WEBHOOK_SECRET=

# -- Circle Admin API v2 (provisioning czlonkow). Poza prod brak = mock.
#    Niesekretne CIRCLE_COMMUNITY_ID jest w sekcji (B).
CIRCLE_API_TOKEN=

# -- Resend (maile transakcyjne). Poza prod brak = mock.
RESEND_API_KEY=

# -- Sender.net (newsletter). Poza prod brak = mock.
SENDER_API_TOKEN=

# -- Meta Conversions API. Bez tokenu integracja po cichu wylaczona.
#    Niesekretne META_PIXEL_ID jest w sekcji (B), ale para musi byc komplet.
META_CAPI_TOKEN=

# -- Sekrety DOI (HMAC) - to NIE klucze zewnetrzne, dowolny mocny string.
#    Pre-wypelnione dev-wartosciami, zeby swiezy `cp .env.example .env` od razu dzialal.
#    W PROD ustaw wlasne, mocne (np. openssl rand -hex 32).
CANCELLATION_DOI_SECRET=dev-cancellation-secret-change-in-prod
NEWSLETTER_DOI_SECRET=dev-newsletter-secret-change-in-prod

# -- Token bootstrapu pierwszego konta Circle (jednorazowy seed). Opcjonalny.
BOOTSTRAP_ADMIN_TOKEN=


# ============================================================
# (B) NIESEKRETNE USTAWIENIA - mozesz ustawic w panelu (Ustawienia)
# Env to tylko domyslny fallback. Wartosc z panelu (DB) nadpisuje env.
# Mozesz zostawic te wartosci puste lub zakomentowane, jesli ustawiasz je w panelu.
# ============================================================

# -- Circle DM / AI (panel: grupa circleDmAi). Interwaly w ms.
CLAUDE_MAX_CONCURRENT=2
POLLING_INTERVAL_MS=30000
KB_BUDGET_TOKENS=60000
KB_HARD_CEILING_TOKENS=90000
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
VOICE_TRANSCRIPT_INTERVAL_MS=20000
IMAGE_DESCRIPTION_INTERVAL_MS=20000

# -- Modele Claude draft/polish. UWAGA: te dwie NIE sa jeszcze w panelu Ustawienia -
#    prompty i modele draft/format Circle DM zyja w osobnym storze circle_dm.settings
#    (API /api/circle-dm/settings), nie w katalogu env-knobow. Na razie ustaw tutaj.
DRAFT_MODEL=claude-sonnet-4-6
POLISH_MODEL=claude-opus-4-7

# -- Workery czlonkostw (panel: grupa membership). Interwaly w ms.
#    To inty z defaultami - nie zostawiaj pustych. Same bramki workerow (cleanup/
#    klarnaReconcile/inviteRetry) zyja tylko w panelu/DB, nie maja zmiennych env.
MEMBERSHIP_CLEANUP_INTERVAL_MS=21600000
KLARNA_RECONCILE_INTERVAL_MS=3600000
INVITE_RETRY_INTERVAL_MS=3600000

# -- Billing / newsletter (panel: grupa billingNewsletter).
FRONTEND_URL=
CONFIRM_URL_BASE=
CANCELLATION_FROM_EMAIL=dev@befreeclub.pl
NEWSLETTER_FROM_EMAIL=dev@befreeclub.pl
SENDER_GROUP_IDS=
EBOOK_FILE_PATH=

# -- Analytics (panel: grupa analytics). Niesekretne identyfikatory.
META_PIXEL_ID=
CIRCLE_COMMUNITY_ID=


# ============================================================
# (C) INFRA / DEV - zostaja w env (boot, baza, flagi mockow)
# ============================================================

# -- Runtime serwera.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# -- WYMAGANE TWARDO: bez tego backend NIE wstanie (exit 1).
CLAUDE_BIN_PATH=/Users/tomasz/.local/bin/claude

# -- Baza: albo DATABASE_URL (priorytet), albo DB_*. Lokalnie Postgres.app
#    peer auth: DB_USER = user systemowy, DB_PASS puste. Na VPS DB_PASS to sekret.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=tomasz
DB_PASS=
DB_NAME=befreeclub

# -- Prod: katalog zbudowanego SPA. Puste w dev (Vite na :5173).
WEB_DIST_PATH=

# -- Bootstrap pierwszego konta Circle (circle_dm.accounts) przy starcie - opcjonalny.
#    Token tego konta jest w sekcji (A) jako sekret.
BOOTSTRAP_ADMIN_LABEL=
BOOTSTRAP_ADMIN_EMAIL=

# -- Tryb lokalny / mocki (app/core/dev_mode.py).
#    Puste = auto (mock gdy NODE_ENV != production i brak klucza serwisu).
#    true = wymus mock nawet z kluczem. false = nigdy nie mockuj.
#    Na produkcji flagi sa ignorowane - brak klucza = blad.
#    MOCK_EMAIL: maile jako pliki HTML w backend/.dev-outbox/ (gitignore).
#    MOCK_SENDER: push do Sender.net tylko logowany (INFO), sukces.
#    MOCK_CIRCLE_MEMBERS: fake in-memory zamiast Circle Admin API (tylko modul members;
#      circle_dm zawsze gada z realnym Circle). Stripe i Meta CAPI nie maja mocka.
MOCK_EMAIL=
MOCK_SENDER=
MOCK_CIRCLE_MEMBERS=
