# Be Free Club backend - environment variables.
# Same names as the old Node backend (admin/apps/server/.env.example).
# Empty value = absent / feature off / default baked into the code.
# Single source of truth for env: app/core/config.py (Settings class).
#
# Three sections:
#   (A) SECRETS - must live in env on the server. The 4 integration keys
#       (OpenAI/Resend/Sender/Meta) can also be set in the panel (API connections),
#       encrypted; env is the fallback. Stripe/Circle are env-only (panel: status).
#   (B) NON-SECRET SETTINGS - editable in the panel (Settings). Env is only the
#       default; the panel value (DB) overrides it. Safe to leave empty here.
#   (C) INFRA / DEV - boot, database, mock flags. env only.


# ============================================================
# (A) SECRETS
# ============================================================

# Master key encrypting the panel-editable API keys (API connections): OpenAI/
# Resend/Sender/Meta can be set in the panel, stored Fernet-encrypted. Empty =
# editing keys in the panel is disabled, the env values below still work.
# Generate: openssl rand -base64 32 | tr '+/' '-_'  (44-char Fernet key)
SECRETS_MASTER_KEY=

# OpenAI (STT/whisper + vision). Missing outside prod = mock.
# Settable in the panel (API connections), encrypted; env is the fallback.
OPENAI_API_KEY=

# Stripe CURRENT account. env only (panel: status + test, not editable).
# Locally use ONLY sk_test_ (sk_live_ outside prod blocks startup).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe LEGACY account (second account). Fill only if used. env only.
STRIPE_LEGACY_SECRET_KEY=
STRIPE_LEGACY_WEBHOOK_SECRET=

# Circle Admin API v2 token (member provisioning). Missing outside prod = mock.
# env only (panel: status). Non-secret CIRCLE_COMMUNITY_ID is in section (B).
CIRCLE_API_TOKEN=

# Resend (transactional mail). Missing outside prod = mock.
# Settable in the panel (API connections), encrypted; env is the fallback.
RESEND_API_KEY=

# Sender.net (newsletter). Missing outside prod = mock.
# Settable in the panel (API connections), encrypted; env is the fallback.
SENDER_API_TOKEN=

# Meta Conversions API. Without the token the integration is silently off.
# Settable in the panel (API connections), encrypted; env is the fallback.
# Non-secret META_PIXEL_ID is in section (B), but the pair must be complete.
META_CAPI_TOKEN=

# DOI HMAC secrets - NOT external keys, any strong string. env only.
# Pre-filled with dev values so a fresh `cp .env.example .env` works out of the box.
# In PROD set your own strong values (e.g. openssl rand -hex 32).
CANCELLATION_DOI_SECRET=dev-cancellation-secret-change-in-prod
NEWSLETTER_DOI_SECRET=dev-newsletter-secret-change-in-prod

# Bootstrap token for the first Circle account (one-off seed). Optional. env only.
BOOTSTRAP_ADMIN_TOKEN=


# ============================================================
# (B) NON-SECRET SETTINGS - editable in the panel; env is only the default
# The panel (DB) value overrides env. Safe to leave empty here if you set them
# in the panel.
# ============================================================

# Circle DM / AI (Settings > Circle DM & AI). Intervals in ms.
CLAUDE_MAX_CONCURRENT=2
POLLING_INTERVAL_MS=30000
KB_BUDGET_TOKENS=60000
KB_HARD_CEILING_TOKENS=90000
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
VOICE_TRANSCRIPT_INTERVAL_MS=20000
IMAGE_DESCRIPTION_INTERVAL_MS=20000

# Claude draft/polish models. Editable in the Circle DM tool settings
# (/circle-dm/settings, "AI models"); env is the default. POLISH_MODEL is
# labelled "Format model" there.
DRAFT_MODEL=claude-sonnet-4-6
POLISH_MODEL=claude-opus-4-7

# Membership workers (Settings > Membership). Intervals in ms - INTs with
# defaults, do not leave empty. The worker gates (cleanup / klarnaReconcile /
# inviteRetry) live only in the panel/DB, they have no env vars.
MEMBERSHIP_CLEANUP_INTERVAL_MS=21600000
KLARNA_RECONCILE_INTERVAL_MS=3600000
INVITE_RETRY_INTERVAL_MS=3600000

# Billing / newsletter (Settings > Billing & Newsletter).
FRONTEND_URL=
CONFIRM_URL_BASE=
CANCELLATION_FROM_EMAIL=dev@befreeclub.pl
NEWSLETTER_FROM_EMAIL=dev@befreeclub.pl
SENDER_GROUP_IDS=
EBOOK_FILE_PATH=

# Analytics (Settings > Analytics). Non-secret identifiers.
META_PIXEL_ID=
CIRCLE_COMMUNITY_ID=


# ============================================================
# (C) INFRA / DEV - env only (boot, database, mock flags)
# ============================================================

# Server runtime.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# HARD REQUIREMENT: without this the backend will NOT start (exit 1).
CLAUDE_BIN_PATH=/Users/tomasz/.local/bin/claude

# Database: either DATABASE_URL (takes priority) or DB_*. Locally Postgres.app
# peer auth: DB_USER = system user, DB_PASS empty. On the VPS DB_PASS is a secret.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=tomasz
DB_PASS=
DB_NAME=befreeclub

# Prod: built SPA directory. Empty in dev (Vite on :5173).
WEB_DIST_PATH=

# Bootstrap of the first Circle account (circle_dm.accounts) at startup - optional.
# This account's token is in section (A) as a secret.
BOOTSTRAP_ADMIN_LABEL=
BOOTSTRAP_ADMIN_EMAIL=

# Local mode / mocks (app/core/dev_mode.py).
#   Empty = auto (mock when NODE_ENV != production and the service key is missing).
#   true = force mock even with a key. false = never mock.
#   In production these flags are ignored - a missing key is an error.
#   MOCK_EMAIL: mail lands as HTML files in backend/.dev-outbox/ (gitignored).
#   MOCK_SENDER: push to Sender.net only logged (INFO), success.
#   MOCK_CIRCLE_MEMBERS: fake in-memory instead of the Circle Admin API (members
#     module only; circle_dm always talks to the real Circle). Stripe and Meta
#     CAPI have no mock.
MOCK_EMAIL=
MOCK_SENDER=
MOCK_CIRCLE_MEMBERS=
