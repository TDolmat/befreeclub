# Te same nazwy zmiennych co w starym backendzie Node (admin/apps/server/.env.example).
# Pusta wartosc = brak (BOOTSTRAP_*, WEB_DIST_PATH, OPENAI_API_KEY, DATABASE_URL).

# Baza: albo DATABASE_URL (priorytet, kompatybilnosc ze starym .env), albo DB_*.
# Lokalnie Postgres.app: peer auth bez hasla (DB_USER = user systemowy, DB_PASS puste).
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=tomasz
DB_PASS=
DB_NAME=befreeclub

CLAUDE_BIN_PATH=/Users/tomasz/.local/bin/claude
DRAFT_MODEL=claude-sonnet-4-6
POLISH_MODEL=claude-opus-4-7
CLAUDE_MAX_CONCURRENT=2
POLLING_INTERVAL_MS=30000

KB_BUDGET_TOKENS=60000
KB_HARD_CEILING_TOKENS=90000

PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Puste w dev - workery voice/image loguja WARN i sie nie uruchamiaja.
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
VOICE_TRANSCRIPT_INTERVAL_MS=20000
IMAGE_DESCRIPTION_INTERVAL_MS=20000

# Bootstrap pierwszego konta Circle (circle_dm.accounts) przy starcie - opcjonalny.
BOOTSTRAP_ADMIN_LABEL=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_TOKEN=

# Prod: katalog zbudowanego SPA. Puste w dev (Vite na :5173).
WEB_DIST_PATH=

# ── Faza 2: landing befreeclub.pl ──────────────────────────────────────────
# Nazwy identyczne z sekretami Supabase (docs/spec-landing/config-deploy.md).
# Wszystkie opcjonalne: puste = funkcja wylaczona / default w kodzie modulu.
# Stripe NIGDY nie jest mockowany - lokalnie uzywaj kluczy TESTOWYCH (sk_test_...),
# to oficjalna piaskownica Stripe. Klucz sk_live_ przy NODE_ENV != production
# blokuje start aplikacji (guard w app/core/config.py).
STRIPE_SECRET_KEY=
STRIPE_LEGACY_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LEGACY_WEBHOOK_SECRET=
CIRCLE_API_TOKEN=
CIRCLE_COMMUNITY_ID=
RESEND_API_KEY=
# Sekrety DOI (HMAC) to NIE klucze zewnetrzne - lokalnie wpisz dowolny string
# (np. dev-secret), inaczej flow subscribe/anulowania zwroci 500.
CANCELLATION_DOI_SECRET=
CANCELLATION_FROM_EMAIL=
NEWSLETTER_DOI_SECRET=
NEWSLETTER_FROM_EMAIL=
CONFIRM_URL_BASE=
FRONTEND_URL=
SENDER_API_TOKEN=
SENDER_GROUP_IDS=
META_PIXEL_ID=
META_CAPI_TOKEN=
EBOOK_FILE_PATH=

# Interwaly workerow fazy 2 (ms). Cleanup: default 6 h - DO POTWIERDZENIA
# ze zrzutem cron.job z prod Supabase przy migracji (PLAN_LANDING pkt 1).
# UWAGA: to inty z defaultami - nie zostawiaj pustych wartosci.
MEMBERSHIP_CLEANUP_INTERVAL_MS=21600000
KLARNA_RECONCILE_INTERVAL_MS=3600000
INVITE_RETRY_INTERVAL_MS=3600000

# ── Tryb lokalny / mocki (app/core/dev_mode.py) ─────────────────────────────
# Konwencja dev: gdy NODE_ENV != production i brak klucza danego serwisu,
# serwis przechodzi w tryb mock z jednym WARN przy starcie (zamiast 500).
# Puste = auto. true = wymus mock nawet z kluczem. false = nigdy nie mockuj.
# Na produkcji flagi sa ignorowane - nic sie nie mockuje, brak klucza = blad.
# MOCK_EMAIL: maile laduja jako pliki HTML w backend/.dev-outbox/ (gitignore).
# MOCK_SENDER: push subskrybenta do Sender.net tylko logowany (INFO), sukces.
# MOCK_CIRCLE_MEMBERS: fake in-memory zamiast Circle Admin API (invite = rosnace
#   fake id od 900001, remove = sukces, find/list = pusto). Dotyczy TYLKO modulu
#   members; circle_dm zawsze gada z realnym Circle (konta testowe).
# Stripe i Meta CAPI NIE maja mocka: Stripe = klucze testowe sk_test_,
# Meta CAPI bez tokenu jest po prostu wylaczone (WARN przy starcie).
MOCK_EMAIL=
MOCK_SENDER=
MOCK_CIRCLE_MEMBERS=
